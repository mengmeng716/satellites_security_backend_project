# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=satellite_security_db
DB_USER=root
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=123456

# Published ports
BACKEND_EXPOSE_PORT=8000

# Backend runtime tuning
# MySQL timeout settings used by docker-compose.yml mysql command.
# Unit: seconds. Set both values >= longest single task duration.
# Example: 432000 = 120 hours (5 days).
MYSQL_WAIT_TIMEOUT_SECONDS=432000
MYSQL_INTERACTIVE_TIMEOUT_SECONDS=432000

# Legacy field kept for compatibility with older scripts (currently not used by compose).
DB_WAIT_TIMEOUT=120
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=300
